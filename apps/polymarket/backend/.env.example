# Runtime
ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./ultramar.db

# Polymarket
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_API_KEY=
POLYMARKET_TIMEOUT_SECONDS=10
POLYMARKET_MARKET_DATA_MODE=auto
POLYMARKET_DUAL_RUN_COMPARE=true
POLYMARKET_SDK_FALLBACK_TO_LEGACY=true

# Gamma / Deribit
GAMMA_BASE_URL=https://gamma-api.polymarket.com
DERIBIT_BASE_URL=https://www.deribit.com/api/v2
DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2

# Storage
RAW_STORE_ROOT=./data/raw

# Risk
MAX_CAPITAL_USD=100000
MAX_POSITION_USD=10000
MAX_PORTFOLIO_USD=100000
DAILY_LOSS_LIMIT_USD=15000
MIN_TRADE_USD=10
KELLY_FRACTION=0.25
DELTA_BAND_FRACTION=0.20
MIN_HEDGE_NOTIONAL_USD=10
