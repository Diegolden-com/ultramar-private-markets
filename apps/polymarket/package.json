{
  "name": "@ultramar/polymarket",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "backend:lint": "cd backend && if [ -x .venv/bin/python ]; then .venv/bin/python -m ruff check backend tests; else python3 -m ruff check backend tests; fi",
    "backend:test": "cd backend && if [ -x .venv/bin/python ]; then .venv/bin/python -m pytest; else python3 -m pytest; fi",
    "qa:frontend": "yarn lint && yarn typecheck && yarn build",
    "qa:backend": "yarn backend:lint && yarn backend:test",
    "qa": "yarn qa:frontend && yarn qa:backend && yarn test:e2e",
    "playwright:install": "playwright install --with-deps chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "hooks:install": "lefthook install",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lefthook": "^2.1.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
